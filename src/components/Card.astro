---
import { Icon } from "astro-icon/components";

const { href, title, body, date, tags, attributes, image } = Astro.props;
---

<li class="link-card">
  <a href={href}>
    <div class="left">
      {title && <h3> {title} </h3>}

      {body && <p> {body} </p>}

      <div class="footer">
        {
          date && (
            <span class="date">
              <Icon name="mdi:calendar" /> {date}
            </span>
          )
        }

        {
          tags?.length && (
            <div class="tags">
              {tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }

        {
          attributes?.length && (
            <div class="attributes">
              {attributes.slice(0, 3).map((attribute) => (
                <span class="attribute">{attribute}</span>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <div class="right" style={`background-image: url(${image?.url})`}></div>
  </a>
</li>
