---
interface Props {
	title: string;
	body: string;
	href: string;
	image?: { url: string; alt: string };
}

const { href, title, body, image } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		<div class="left">
			{ title && (<h3> {title} </h3>) }

			{ body && (<p> {body} </p>) }
		</div>

		<div class="right" style={`background-image: url(${image?.url})`}>
		</div>
	</a>
</li>