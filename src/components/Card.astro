---
import { Icon } from "astro-icon/components";

interface ImageData {
  url: string;
  alt: string;
}

interface Props {
  href: string;
  title?: string;
  body?: string;
  date?: string;
  tags?: string[];
  attributes?: string[];
  image?: ImageData;
}

const { href, title, body, date, tags, attributes, image } =
  Astro.props as Props;
---

<li class="link-card">
  <a href={href}>
    <div class="left">
      {title && <h3> {title} </h3>}

      {body && <p> {body} </p>}

      <div class="footer">
        {
          date && (
            <span class="date">
              <Icon name="mdi:calendar" /> {date}
            </span>
          )
        }

        {
          tags?.length && (
            <div class="tags">
              {tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }

        {
          attributes?.length && (
            <div class="attributes">
              {attributes.slice(0, 3).map((attribute) => (
                <span class="attribute">{attribute}</span>
              ))}
            </div>
          )
        }
      </div>
    </div>

    {
      image?.url && (
        <div
          class="right"
          style={`background-image: url(${image.url})`}
          aria-hidden="true"
          role="presentation"
        />
      )
    }
  </a>
</li>

<script is:inline>
  (() => {
    if (typeof window === "undefined") return;
    const root = document.documentElement;
    if (root.dataset.cardTooltipInit === "1") return;
    root.dataset.cardTooltipInit = "1";

    const setTooltips = () => {
      document.querySelectorAll("li.link-card").forEach((card) => {
        const titleEl = card.querySelector(".left h3") as HTMLElement | null;
        const anchor = card.querySelector("a") as HTMLAnchorElement | null;
        if (!titleEl || !anchor) return;
        const isClamped = titleEl.scrollHeight > titleEl.clientHeight + 1;
        const full = (titleEl.textContent || "").trim();
        if (isClamped && full) {
          anchor.setAttribute("title", full);
          anchor.setAttribute("aria-label", full);
        } else {
          anchor.removeAttribute("title");
          anchor.removeAttribute("aria-label");
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setTooltips, {
        once: true,
      });
    } else {
      setTooltips();
    }

    window.addEventListener("resize", setTooltips);
  })();
</script>
