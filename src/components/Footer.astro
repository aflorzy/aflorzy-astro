---
import Social, { Socials } from "./Social.astro";
---

<footer>
  <div class="socials">
    <Social platform={Socials.LinkedIn} url="linkedin.com/in/andrewtflores" />
    <Social platform={Socials.GitHub} url="github.com/aflorzy" />
    <Social platform={Socials.YouTube} url="youtube.com/andrewflorzy" />
    <Social platform={Socials.RSS} url="blog.aflorzy.com/rss.xml" />
  </div>

  <p>&copy; {new Date().getFullYear()} Florzy Tech, LLC.</p>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    align-items: center;
    margin-top: 2rem;
    min-height: 5rem;
  }
  .socials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  p {
    font-size: 0.7rem;
    color: #555;
  }
</style>
