---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.scss";

const { pageTitle, pageDescription, ogImageUrl, ogType } = Astro.props;

// Derive a stable origin even if Astro.site is not configured
const origin = (Astro.site ?? Astro.url.origin);
const canonical = new URL(Astro.url.pathname, origin);
const resolvedOgType = ogType ?? "website";
const resolvedOgImage = new URL(ogImageUrl ?? "/images/favicon.png", origin);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Andrew Flores RSS"
      href={new URL("rss.xml", origin)}
    />
    <link rel="canonical" href={canonical} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="blog.aflorzy.com" />
    <meta property="twitter:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        // @ts-expect-error dynamic dataLayer index
        w[l] = w[l] || [];
        // @ts-expect-error dynamic dataLayer index
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s) as HTMLScriptElement,
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        j.type = "text/partytown";
        // @ts-expect-error Error comes from Google Tag Manager
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-TBX4N52R");
    </script>
    <!-- End Google Tag Manager -->
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TBX4N52R"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->

    <Header />

    <h1>{pageTitle}</h1>

    <div class="content">
      <slot />
    </div>

    <Footer />

    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>
