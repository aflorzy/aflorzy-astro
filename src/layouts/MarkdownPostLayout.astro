---
import { Image } from "astro:assets";
import daytrackr from "../assets/daytrackr.png";
import flotrade from "../assets/flotrade.png";
import * as use from "../components/switch-case";
import Tag from "../components/Tag.astro";
import BaseLayout from "./BaseLayout.astro";

const { frontmatter, created, updated } = Astro.props;

const ogType = frontmatter.pubDate ? "article" : "website";
type FrontImage = string | { url?: string } | undefined;
const fmImage: FrontImage = (frontmatter as Record<string, unknown> | undefined)?.image as FrontImage;
const ogImageUrl = typeof fmImage === "string" ? fmImage : fmImage?.url;
const tags: string[] = (frontmatter.tags ?? []) as string[];
---

<BaseLayout
  pageTitle={frontmatter.title}
  pageDescription={frontmatter.description}
  ogType={ogType}
  ogImageUrl={ogImageUrl}>
  {created && <p>Published {created}</p>}
  {updated && updated !== created && <p>Updated {updated}</p>}

  {
    frontmatter.description && (
      <p>
        <em>{frontmatter.description}</em>
      </p>
    )
  }

  {
    frontmatter.authors?.length && (
      <p>Written by {frontmatter.authors.join(", ")}</p>
    )
  }

  <use.switch value={frontmatter.title}>
    <use.case slot="FloTrade">
      <Image
        src={flotrade}
        alt="FloTrade logo"
        format="webp"
        height="300"
        quality="mid"
      />
    </use.case>

    <use.case slot="DayTrackr">
      <Image
        src={daytrackr}
        alt="DayTrackr logo"
        format="webp"
        height="300"
        quality="mid"
      />
    </use.case>
  </use.switch>

  {tags.length > 0 && (
    <div class="tags">
      {tags.map((tag: string) => (
        <Tag tag={tag} />
      ))}
    </div>
  )}

  <slot />
</BaseLayout>
