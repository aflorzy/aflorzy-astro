---
import Tag from "../components/Tag.astro";
import { formatDate } from "../scripts/formatDate"
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
    { frontmatter.pubDate && <p>Published on {formatDate(frontmatter.pubDate)}</p> }

    { frontmatter.description && <p><em>{frontmatter.description}</em></p> }

    { frontmatter.authors?.length && <p>Written by {frontmatter.authors.join(', ')}</p> }

    { frontmatter.image && <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} /> }

    { frontmatter.tags?.length && (
        <div class="tags">
            { frontmatter.tags.map((tag) => <Tag tag={tag} />)}
        </div> 
    )}

    <slot />
</BaseLayout>