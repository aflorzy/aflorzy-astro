---
import { Image } from "astro:assets";
import daytrackr from "../assets/daytrackr.png";
import flotrade from "../assets/flotrade.png";
import * as use from "../components/switch-case";
import Tag from "../components/Tag.astro";
import BaseLayout from "./BaseLayout.astro";

const { frontmatter, created, updated } = Astro.props;

type BlogFM = {
  title: string;
  description: string;
  pubDate?: Date;
  lastModified?: Date;
  authors?: string[];
  image?: { url?: string } | string;
  tags?: string[];
};

const fm = frontmatter as BlogFM;
const ogType = fm.pubDate ? "article" : "website";
const ogImageUrl = typeof fm.image === "string" ? fm.image : fm.image?.url;
const tags: string[] = (fm.tags ?? []) as string[];

// JSON-LD (schema.org) for blog posts
const origin = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, origin).toString();
const authors: string[] = (fm.authors ?? []) as string[];
const datePublishedIso = fm.pubDate
  ? new Date(fm.pubDate).toISOString()
  : undefined;
const dateModifiedIso = fm.lastModified
  ? new Date(fm.lastModified).toISOString()
  : undefined;

const jsonData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: fm.title,
  description: fm.description,
  url: canonical,
  datePublished: datePublishedIso,
  dateModified: dateModifiedIso,
  author: authors.map((name) => ({ "@type": "Person", name })),
  image: ogImageUrl ? [ogImageUrl] : undefined,
};
---

<BaseLayout
  pageTitle={frontmatter.title}
  pageDescription={frontmatter.description}
  ogType={ogType}
  ogImageUrl={ogImageUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonData)} />
  </Fragment>
  {created && <p>Published {created}</p>}
  {updated && updated !== created && <p>Updated {updated}</p>}

  {
    frontmatter.description && (
      <p>
        <em>{frontmatter.description}</em>
      </p>
    )
  }

  {
    frontmatter.authors?.length && (
      <p>Written by {frontmatter.authors.join(", ")}</p>
    )
  }

  <use.switch value={frontmatter.title}>
    <use.case slot="FloTrade">
      <Image
        src={flotrade}
        alt="FloTrade logo"
        format="webp"
        height="300"
        quality="mid"
      />
    </use.case>

    <use.case slot="DayTrackr">
      <Image
        src={daytrackr}
        alt="DayTrackr logo"
        format="webp"
        height="300"
        quality="mid"
      />
    </use.case>
  </use.switch>

  {
    tags.length > 0 && (
      <div class="tags">
        {tags.map((tag: string) => (
          <Tag tag={tag} />
        ))}
      </div>
    )
  }

  <slot />
</BaseLayout>
