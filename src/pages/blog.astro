---
import BlogPost from "../components/BlogPost.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { publishedPosts } from "../utilities/getPosts.astro";
import { postHref } from "../utilities/urls";
import Search from "../components/Search";

let posts = publishedPosts.sort(
  ({ data: a }, { data: b }) =>
    new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);

const pageTitle = "Blog";
const pageDescription =
  "Simplify learning in the homelab with Docker, Linux, and much more!";
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <Search client:idle />
  <ul class="link-card-grid" id="post-list">
    {
      posts.map(({ data, slug }) => (
        <BlogPost
          url={postHref(slug)}
          title={data.title}
          description={data.description}
          pubDate={data.pubDate}
          tags={data.tags}
        />
      ))
    }
  </ul>
</BaseLayout>
