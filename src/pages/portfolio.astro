---
import PortfolioProject from "../components/PortfolioProject.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllProjects } from "../utilities/getProjects.astro";

const allProjects = await getAllProjects().then((allPosts) =>
  allPosts.filter((post) => !post.frontmatter.disabled)
);

const pageTitle = "My Projects";
---

<BaseLayout pageTitle={pageTitle}>
  <ul class="link-card-grid">
    {
      allProjects.map((project) => (
        <PortfolioProject
          url={project.url}
          title={project.frontmatter.title}
          description={project.frontmatter.description}
          image={project.frontmatter.image}
        />
      ))
    }
  </ul>
</BaseLayout>
