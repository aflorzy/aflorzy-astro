---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Test";
---

<BaseLayout pageTitle={pageTitle}>
  <header>
    <h1>Heading Level 1</h1>
    <h2>Heading Level 2</h2>
    <h3>Heading Level 3</h3>
    <h4>Heading Level 4</h4>
    <h5>Heading Level 5</h5>
    <h6>Heading Level 6</h6>
  </header>

  <section>
    <h2>Text Elements</h2>
    <p>This is a paragraph. It contains some <strong>bold text</strong>, <em>italic text</em>, and a <a href="#">link</a>.</p>
    <p>Here's a <mark>highlighted text</mark> example.</p>
  </section>

  <section>
    <h2>Lists</h2>
    <h3>Unordered List</h3>
    <ul>
      <li>List Item 1</li>
      <li>List Item 2
        <ul>
          <li>Nested List Item</li>
        </ul>
      </li>
      <li>List Item 3</li>
    </ul>
    
    <h3>Ordered List</h3>
    <ol>
      <li>First Item</li>
      <li>Second Item</li>
      <li>Third Item</li>
    </ol>
  </section>

  <section>
    <h2>Blockquote</h2>
    <blockquote>
      "This is a blockquote example. It should stand out and have some distinct styling."
    </blockquote>
  </section>

  <section>
    <h2>Code</h2>
    <p>Inline code example: <code>let x = 10;</code></p>
    <pre><code>console.log("Hello, " + name); greet("World"); </code></pre>
  </section>

  <section>
    <h2>Table</h2>
    <table>
      <thead>
        <tr>
          <th>Header 1</th>
          <th>Header 2</th>
          <th>Header 3</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Row 1, Cell 1</td>
          <td>Row 1, Cell 2</td>
          <td>Row 1, Cell 3</td>
        </tr>
        <tr>
          <td>Row 2, Cell 1</td>
          <td>Row 2, Cell 2</td>
          <td>Row 2, Cell 3</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Images</h2>
    <p>Here is an example image:</p>
    <img src="https://via.placeholder.com/400x200" alt="Placeholder image">
  </section>

  <section>
    <h2>Gradients</h2>
    <div class="gradient-primary" style="padding: 1rem; color: white;">
      Primary Gradient Background
    </div>
    <div class="gradient-secondary" style="padding: 1rem; color: white;">
      Secondary Gradient Background
    </div>
  </section>
</BaseLayout>