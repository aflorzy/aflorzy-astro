---
import { CollectionEntry, getCollection } from "astro:content";

export const allPosts = await getCollection("blog").then((entries) =>
  entries.map((entry) => ({ ...entry, slug: `/posts/${entry.slug}` }))
);

export const publishedPosts = allPosts.filter(
  ({ data }: CollectionEntry<"blog">) => !data.draft
);

export const draftPosts = allPosts.filter(
  ({ data }: CollectionEntry<"blog">) => !!data.draft
);
---
