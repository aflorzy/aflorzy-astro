---
import { CollectionEntry, getCollection } from "astro:content";

export interface BlogEntry {
  data: CollectionEntry<"blog">;
  slug: string;
}

export const allPosts: BlogEntry[] = await getCollection("blog").then(
  (entries: BlogEntry[]) =>
    entries.map((entry) => ({ ...entry, slug: `/posts/${entry.slug}` }))
);

export const publishedPosts = allPosts.filter(({ data }) => !data.draft);

export const draftPosts = allPosts.filter(({ data }) => !!data.draft);
---
