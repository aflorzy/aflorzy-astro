---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

export type ProjectEntry = CollectionEntry<"project">;

export const allProjects: ProjectEntry[] = await getCollection("project");

export const publishedProjects: ProjectEntry[] = allProjects.filter(
  (project) => !project.data.draft
);

export const draftProjects: ProjectEntry[] = allProjects.filter(
  (project) => !!project.data.draft
);
---
